{
  "name": "vue-base-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "type:check": "vue-tsc --build --noEmit",
    "lint": "oxlint --fix ./src ./packages/**/src",
    "lint:check": "oxlint ./src ./packages/**/src",
    "format": "oxfmt src/ packages/**/src/",
    "format:check": "oxfmt --check src/ packages/**/src/"
  },
  "dependencies": {
    "@base-ui/utils": "workspace:*",
    "@base-ui/vue": "workspace:*",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "unplugin-vue-markdown": "^30.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  }
}